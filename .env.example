# ── Site ──────────────────────────────────────────────────────────────────────
# Your production front-end URL (used for canonical URLs and sitemaps)
SITE_URL=https://yoursite.com

# ── WordPress ─────────────────────────────────────────────────────────────────
# Your WordPress site URL (no trailing slash) — can be the same as SITE_URL
# if WP and the front-end share a domain, or a separate URL if WP is headless-only
WP_URL=https://yoursite.com

# ── WooCommerce (only needed if using AdBlock / WC features) ──────────────────
# Generate keys in WP Admin → WooCommerce → Settings → Advanced → REST API
# Read-only keys are sufficient for the front-end.
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
