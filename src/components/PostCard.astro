---
// src/components/PostCard.astro
import type { WPPost } from '../lib/types';
import { getFeaturedImageUrl, formatDate, excerptFromContent } from '../lib/wordpress';

interface Props {
  post: WPPost;
}

const { post } = Astro.props;

const image   = getFeaturedImageUrl(post, 'medium');
const date    = formatDate(post.date);
const excerpt = post.excerpt?.rendered
  ? post.excerpt.rendered.replace(/<[^>]+>/g, '').trim()
  : excerptFromContent(post.content.rendered);

const categories = post._embedded?.['wp:term']?.[0] ?? [];
---

<article class="post-card">
  {image && (
    <a href={`/blog/${post.slug}/`} class="post-card-image-wrap">
      <img src={image} alt={post.title.rendered} class="post-card-image" loading="lazy" />
    </a>
  )}
  <div class="post-card-body">
    {categories.length > 0 && (
      <div class="post-card-cats">
        {categories.map(cat => (
          <a href={`/category/${cat.slug}/`} class="post-card-cat">{cat.name}</a>
        ))}
      </div>
    )}
    <h2 class="post-card-title">
      <a href={`/blog/${post.slug}/`} set:html={post.title.rendered} />
    </h2>
    <p class="post-card-excerpt">{excerpt}</p>
    <div class="post-card-meta">
      <time datetime={post.date}>{date}</time>
    </div>
  </div>
</article>

<style>
  .post-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s;
  }

  .post-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.1); }

  .post-card-image-wrap { display: block; overflow: hidden; }

  .post-card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform .3s;
  }

  .post-card-image-wrap:hover .post-card-image { transform: scale(1.03); }

  .post-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    flex: 1;
  }

  .post-card-cats {
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
  }

  .post-card-cat {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--color-primary);
    text-decoration: none;
  }

  .post-card-title {
    font-size: 1.05rem;
    margin: 0;
  }

  .post-card-title a {
    color: var(--color-dark);
    text-decoration: none;
    font-weight: 700;
  }

  .post-card-title a:hover { color: var(--color-primary); }

  .post-card-excerpt {
    font-size: .875rem;
    color: var(--color-gray);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .post-card-meta {
    font-size: .8rem;
    color: var(--color-gray);
  }
</style>
