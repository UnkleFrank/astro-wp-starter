---
// src/components/RichText.astro
// Renders WordPress HTML content with scoped styles.
// Handles the Gutenberg/Classic editor HTML output.

interface Props {
  content: string;
  class?: string;
}

const { content, class: className = '' } = Astro.props;
---

<div class:list={['wp-content', className]} set:html={content} />

<style>
  .wp-content {
    max-width: 72ch;
    color: var(--color-dark, #1a1a2e);
    line-height: 1.75;
  }

  .wp-content :global(h1),
  .wp-content :global(h2),
  .wp-content :global(h3),
  .wp-content :global(h4),
  .wp-content :global(h5),
  .wp-content :global(h6) {
    margin-top: 2em;
    margin-bottom: .5em;
    line-height: 1.25;
  }

  .wp-content :global(p) {
    margin-top: 0;
    margin-bottom: 1.25em;
  }

  .wp-content :global(ul),
  .wp-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }

  .wp-content :global(li) { margin-bottom: .4em; }

  .wp-content :global(a) {
    color: var(--color-primary, #1a8286);
    font-weight: 600;
  }

  .wp-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius, 8px);
    margin: 1rem 0;
  }

  .wp-content :global(blockquote) {
    border-left: 4px solid var(--color-primary, #1a8286);
    margin: 1.5em 0;
    padding: .75em 1.25em;
    background: var(--color-light, #f9fafb);
    border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
  }

  .wp-content :global(blockquote p) { margin: 0; }

  .wp-content :global(pre) {
    background: #1e1e2e;
    color: #cdd6f4;
    padding: 1.25rem;
    border-radius: var(--radius, 8px);
    overflow-x: auto;
    font-size: .875rem;
    line-height: 1.6;
  }

  .wp-content :global(code) {
    font-size: .875em;
    background: #f1f5f9;
    padding: .15em .4em;
    border-radius: 4px;
  }

  .wp-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .wp-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: .9rem;
  }

  .wp-content :global(th),
  .wp-content :global(td) {
    border: 1px solid var(--color-border, #e5e7eb);
    padding: .6rem .85rem;
    text-align: left;
  }

  .wp-content :global(th) {
    background: var(--color-light, #f9fafb);
    font-weight: 700;
  }

  /* Gutenberg alignment classes */
  .wp-content :global(.alignwide)  { max-width: 110%; margin-left: -5%; }
  .wp-content :global(.alignfull)  { max-width: 100vw; margin-left: calc(50% - 50vw); }
  .wp-content :global(.alignleft)  { float: left; margin-right: 1.5rem; margin-bottom: 1rem; }
  .wp-content :global(.alignright) { float: right; margin-left: 1.5rem; margin-bottom: 1rem; }
  .wp-content :global(.aligncenter) { margin-left: auto; margin-right: auto; display: block; }

  /* Gutenberg button block */
  .wp-content :global(.wp-block-button__link) {
    display: inline-block;
    background: var(--color-primary, #1a8286);
    color: white !important;
    padding: .6rem 1.4rem;
    border-radius: 6px;
    font-weight: 700;
    text-decoration: none;
    font-size: .95rem;
  }

  /* Gallery */
  .wp-content :global(.wp-block-gallery) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: .75rem;
    margin-bottom: 1.5em;
  }
</style>
